/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    mtbc-speciation-nf  Nextflow config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    // Core inputs
    input             = null
    outdir            = 'results'
    reference         = "${projectDir}/assets/H37Rv.fasta"

    // Behaviour
    run_phylo         = false
    publish_dir_mode  = 'copy'

    // Max resource ceilings (overridden per-profile)
    max_cpus          = 8
    max_memory        = '16.GB'
    max_time          = '24.h'
}

// Load the base resource labels
includeConfig 'conf/base.config'

profiles {
    test  { includeConfig 'conf/test.config'  }
    local { includeConfig 'conf/local.config' }
    hpc   { includeConfig 'conf/hpc.config'   }
    cloud { includeConfig 'conf/cloud.config' }
}

manifest {
    name            = 'mtbc-speciation-nf'
    author          = 'Hailey Gavigan'
    description     = 'Zoonotic TB genomic surveillance with full MTBC speciation'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '0.1.0'
}
