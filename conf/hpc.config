// UA HPC (SLURM). Apptainer wiring is intentionally left commented until
// containers are added, so this profile works with module-loaded tools too.
//
// NOTE: --account below is your SLURM ALLOCATION GROUP (whose compute budget the
// job charges to), NOT your login name (gaviganh). It's usually your PI's group
// e.g. the same group as your xdisk path. Check with:  va   or   sacctmgr show assoc user=gaviganh
process {
    executor       = 'slurm'
    queue          = 'standard'
    clusterOptions = '--account=REPLACE_WITH_YOUR_ALLOCATION_GROUP'
}

executor {
    queueSize       = 50
    submitRateLimit = '10/1min'
}

// Uncomment once containers exist (see README roadmap):
// apptainer {
//     enabled    = true
//     autoMounts = true
//     cacheDir   = "/xdisk/<your_pi_group>/gaviganh/.apptainer/cache"
// }
