// Default per-process resource labels. Profiles can override the executor.
process {
    cpus   = 2
    memory = '4.GB'
    time   = '4.h'

    withLabel:process_low    { cpus = 2; memory = '4.GB';  time = '2.h' }
    withLabel:process_medium { cpus = 4; memory = '8.GB';  time = '6.h' }
    withLabel:process_high   { cpus = 8; memory = '16.GB'; time = '12.h' }

    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 1
}
