// Minimal profile: runs the whole DAG on tiny bundled data.
// Pair with -stub-run in CI so no tools/containers are needed yet.
// CPU/memory capped low so it fits free CI runners (2-4 cores).
params {
    input      = "${projectDir}/assets/samplesheet_test.csv"
    reference  = "${projectDir}/assets/test_data/ref_stub.fasta"
    max_cpus   = 2
    max_memory = '6.GB'
}

process {
    resourceLimits = [ cpus: 2, memory: '6.GB', time: '1.h' ]
}
